{
  "manifest_version": 3,
  "name": "EtsyShield — Compliance + SEO Scanner",
  "version": "1.1.0",
  "description": "Protect your Etsy shop from suspension and optimize listings for search. Trademark checking + SEO analysis in one click.",
  "permissions": ["storage", "activeTab", "alarms"],
  "host_permissions": ["https://www.etsy.com/*", "https://*.etsy.com/*", "https://etsyshield-api.max-dobrikf.workers.dev/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.etsy.com/listing/*", "https://www.etsy.com/*/listing/*", "https://www.etsy.com/shop/*", "https://www.etsy.com/*/shop/*"],
      "js": ["content/etsy-parser.js"]
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
